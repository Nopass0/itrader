generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Admins who can create user accounts
model Admin {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  password  String
  token     String   @unique
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  users     User[]

  @@map("admins")
}

// Users who can access the system
model User {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  password  String
  adminId   Int      @map("admin_id")
  admin     Admin    @relation(fields: [adminId], references: [id])
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  
  // Platform credentials
  gateCredentials     GateCredentials?
  bybitCredentials    BybitCredentials?
  
  // Sessions
  gateSessions        GateSession[]
  bybitSessions       BybitSession[]

  @@map("users")
}

// Gate.cx credentials
model GateCredentials {
  id        Int      @id @default(autoincrement())
  userId    Int      @unique @map("user_id")
  email     String
  password  String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("gate_credentials")
}

// Bybit credentials
model BybitCredentials {
  id        Int      @id @default(autoincrement())
  userId    Int      @unique @map("user_id")
  apiKey    String
  apiSecret String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("bybit_credentials")
}

// Gate.cx session
model GateSession {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  cookies   String   @db.Text
  userData  Json
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("gate_sessions")
}

// Bybit session
model BybitSession {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  accountInfo Json
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("bybit_sessions")
}

// Transaction logs
model TransactionLog {
  id        Int      @id @default(autoincrement())
  platform  String   // "gate" or "bybit"
  requestPath String @map("request_path")
  requestData Json   @map("request_data")
  responseData Json  @map("response_data")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("transaction_logs")
}
# Common
NODE_ENV=development

# Server
SERVER_PORT=3000
JWT_SECRET=your_jwt_secret_key_change_in_production
JWT_EXPIRATION=24h
CORS_ORIGINS=http://localhost:3001

# Database
DATABASE_URL=postgresql://aitrader:aitraderpassword@localhost:5432/aitrader

# Gate.cx API
GATE_API_URL=https://panel.gate.cx/api/v1

# Bybit API
BYBIT_API_URL=https://api.bybit.com
BYBIT_TESTNET_API_URL=https://api-testnet.bybit.com
BYBIT_USE_TESTNET=false

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:3000
NEXT_PUBLIC_SOCKET_URL=http://localhost:3000

# Admin
ADMIN_TOKEN=generate_random_token_here

# Session
SESSION_REFRESH_INTERVAL=30

# Logger
LOG_LEVEL=info

# Development settings
ALLOW_DEV_ACCESS=false

# Mock data (for testing)
USE_MOCK_DATA=false